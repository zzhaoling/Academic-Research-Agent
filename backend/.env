# Which search service to use, either 'duckduckgo', 'tavily', 'perplexity', Searxng
SEARCH_API='tavily'

# LLM配置 (从HelloAgents继承,如需覆盖可在此配置)

# 模型提供者
LLM_PROVIDER=custom          # Options: ollama, lmstudio, custom 其中ollama和lmstudio都是用于本地大模型配置，custom是用于自定义大模型配置[用于api调用]
# glm模型
# LLM_MODEL_ID=coding-glm-4.7-free
# LLM_API_KEY=sk-14m3hZLvJDP7ciWr5934F28aFa934d2e9684Ec7e31E6Bf44
# LLM_BASE_URL=https://aihubmix.com/v1

# LLM_MODEL_ID=glm-4-flash
# # LLM_API_KEY=7d120966046a473d90074e18aba56a04.B6LsH095ZIER6yqz
# LLM_API_KEY=7aa4b6a509d5425cb106341beca4bba6.MqyW0Pa1dSTDIemv
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

LLM_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=sk-zxbfxzcnslghzyqdgbyhohhpkqesermltxpwwoptenfatjsd
# 最大重试次数
# OPENAI_MAX_RETRIES=2


# 超时时间
LLM_TIMEOUT=180

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 日志级别
LOG_LEVEL=INFO
# Web Search API Keys (choose one or both)
TAVILY_API_KEY=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      # Get your key at https://tavily.com
# PERPLEXITY_API_KEY=pplx-xxxxx  # Get your key at https://www.perplexity.ai
# For Searxng search, defaults to http://localhost:8888
# SEARXNG_URL=

# 本地模型配置(LMStudio/Ollama)
# LLM_PROVIDER=lmstudio          # Options: ollama, lmstudio
# LOCAL_LLM=qwen_qwq-32b         # Model name in LMStudio/Ollama
# LMSTUDIO_BASE_URL=http://localhost:1234/v1  # LMStudio OpenAI-compatible API URL
# OLLAMA_BASE_URL=http://localhost:11434 # the endpoint of the Ollama service, defaults to http://localhost:11434 if not set

MAX_WEB_RESEARCH_LOOPS=3
FETCH_FULL_PAGE=True

# 记忆配置
ENABLE_MEMORY=true


# RAG 配置
# ENABLE_RAG=true
# RAG_KNOWLEDGE_BASE_PATH=./src/rag_knowledge
ENABLE_HYBRID_RETRIEVAL=true

# ================================
# Qdrant 向量数据库配置
# ================================
# 方案一：使用本地 Docker（推荐开发测试）
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# QDRANT_COLLECTION=hello_agents_vectors
QDRANT_COLLECTION=papers
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30
QDRANT_MODE=docker
PDF_DIR=./src/papers
# 方案二：使用 Qdrant Cloud（生产环境）
# QDRANT_URL=https://your-cluster.qdrant.tech:6333
# QDRANT_API_KEY=your_qdrant_api_key_here

# ================================
# Neo4j 图数据库配置（用于语义记忆）
# ================================
# 方案一：使用本地 Docker
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=zzl20030114
NEO4J_DATABASE=neo4j

# 方案二：使用 Neo4j Aura 云服务
# NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_neo4j_password_here

# ================================
# 嵌入模型配置（文本向量化）
# ================================
# 方案一：使用本地模型（免费，无需 API Key）
EMBED_MODEL_TYPE=local
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_API_KEY=
EMBED_BASE_URL=

# 方案二：使用云端 API（如阿里云 dashscope）
# EMBED_MODEL_TYPE=dashscope
# EMBED_MODEL_NAME=text-embedding-v3
# EMBED_API_KEY=your_dashscope_api_key
# EMBED_BASE_URL=